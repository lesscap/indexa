# 必须和 apps/server 指向同一个 Postgres 和同一个 DOCUMENT_STORAGE_ROOT
# SQLAlchemy URL 必须用 postgresql+psycopg:// 前缀以启用 psycopg 3 驱动
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/indexa
DOCUMENT_STORAGE_ROOT=/Users/bencode/work/lesscap/indexa/apps/server/storage

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=

# DashScope (QWEN)
DASHSCOPE_API_KEY=

# Worker
WORKER_BATCH_SIZE=5
WORKER_ID=dev-local
LOG_LEVEL=INFO
